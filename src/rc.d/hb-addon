#!/bin/sh

ADDON_NAME=`basename "$0"`
ADDON_DISPLAY_NAME="HB-AddOn"
GITHUB_REPO="maxx3105/HB-AddOn"
GITHUB_RELEASES_URL="https://api.github.com/repos/${GITHUB_REPO}/releases/latest"
GITHUB_DOWNLOAD_URL="https://github.com/${GITHUB_REPO}/releases/latest"

ADDON_DIR=/usr/local/addons/${ADDON_NAME}
PATCH_DIR=${ADDON_DIR}/patch
NEW_ADDON_DIR=${ADDON_DIR}-new
WWW_DIR=/usr/local/etc/config/addons/www/$ADDON_NAME

LOG_DIR=${ADDON_DIR}/log
TMP_LOGDIR=/tmp
TMP_LOGFILE=${TMP_LOGDIR}/${ADDON_NAME}-inst.log
TMP_ERRFILE=${TMP_LOGDIR}/${ADDON_NAME}-inst.err

FIRMWARE_DIR=/firmware/rftypes
RC_DIR=/usr/local/etc/config/rc.d
CK_FIRMWARE_FILE=${FIRMWARE_DIR}/hb-uni-sen-pool-wp.xml

PATCHSUBDIR_COMMON=common

check_ccu_fw_version()
{
  model=`grep VERSION /boot/VERSION   | awk -F'[=.]' {'print $2'}`
  version=`grep VERSION /boot/VERSION | awk -F'[=.]' {'print $3'}`
  build=`grep VERSION /boot/VERSION   | awk -F'[=.]' {'print $4'}`

  if [ $model -ge 2 ] && [ $version -le 43 ]; then
    echo "Unsupported firmware version $model.$version.$build found." | tee -a $TMP_LOGFILE | tee -a $TMP_ERRFILE
    exit 14
  fi

  echo "Found firmware version $model.$version.$build" | tee -a $TMP_LOGFILE | tee -a $TMP_ERRFILE
}

get_latest_version()
{
  local latest=""
  if which wget >/dev/null 2>&1; then
    latest=$(wget -q -T 5 -O - "${GITHUB_RELEASES_URL}" 2>/dev/null \
      | grep '"tag_name"' \
      | head -1 \
      | sed 's/.*"tag_name"[[:space:]]*:[[:space:]]*"v\{0,1\}\([^"]*\)".*/\1/')
  fi
  echo "${latest}"
}

convert_lf()
{
  filename=`sed -n '2p' $1 | sed 's/+++ .\\/patchsource//g' | awk {'print $1'}`
  dos2unix $filename 2>/dev/null

  cmpresult=`unix2dos < $filename | cmp - $filename`
  if [ "$cmpresult" ]; then
    cmpresult=`dos2unix < $1 | cmp - $1`
    if [ "$cmpresult" ]; then
      echo "dos2unix conversion needed for $1" | tee -a $TMP_LOGFILE
      dos2unix $1 2>/dev/null | tee -a $TMP_LOGFILE | tee -a $TMP_ERRFILE
    fi
  fi
}

MONIT=0
check_monit()
{
  MONIT=`ps -ef|grep \/usr\/bin\/monit|grep -v grep|wc -l`
  echo "Found $MONIT monit process(es)" | tee -a $TMP_LOGFILE
}

REGA=0
check_rega()
{
  REGA=`ps -ef|grep \/bin\/ReGaHss|grep -v grep|wc -l`
  echo "Found $REGA ReGaHss process(es)" | tee -a $TMP_LOGFILE
}

RFD=0
check_rfd()
{
  RFD=`ps -ef|grep \/bin\/rfd|grep -v grep|wc -l`
  echo "Found $RFD rfd process(es)" | tee -a $TMP_LOGFILE
}

cleanup_orig_files()
{
  [ -f /www/webui/webui.js.orig ]                  && rm /www/webui/webui.js.orig
  [ -f /www/config/ic_deviceparameters.cgi.orig ]  && rm /www/config/ic_deviceparameters.cgi.orig
}

WEBUI_JS=/www/webui/webui.js
WEBUI_ANCHOR='DEV_PATHS\["HM-RC-4-3"\]\["250"\]'
WEBUI_MARKER='HB-UNI-Sen-POOL-WP'
WEBUI_ELVST_ANCHOR="elvST\['WEATHER'\]"
WEBUI_ELVST_MARKER='HB_GENERIC.*Pool Waermepumpe'

WEBUI_INSERT='DEV_HIGHLIGHT['"'"'HB-UNI-Sen-POOL-WP'"'"'] = new Object();\
DEV_LIST.push('"'"'HB-UNI-Sen-POOL-WP'"'"');\
DEV_DESCRIPTION['"'"'HB-UNI-Sen-POOL-WP'"'"']='"'"'Pool Waermepumpe Controller'"'"';\
DEV_PATHS['"'"'HB-UNI-Sen-POOL-WP'"'"'] = new Object();\
DEV_PATHS['"'"'HB-UNI-Sen-POOL-WP'"'"']['"'"'50'"'"'] = '"'"'/config/img/devices/50/hb-uni-sen-pool-wp_thumb.png'"'"';\
DEV_PATHS['"'"'HB-UNI-Sen-POOL-WP'"'"']['"'"'250'"'"'] = '"'"'/config/img/devices/250/hb-uni-sen-pool-wp.png'"'"';\
DEV_HIGHLIGHT['"'"'HB-UNI-Sen-EC'"'"'] = new Object();\
DEV_LIST.push('"'"'HB-UNI-Sen-EC'"'"');\
DEV_DESCRIPTION['"'"'HB-UNI-Sen-EC'"'"']='"'"'EC-Sensor'"'"';\
DEV_PATHS['"'"'HB-UNI-Sen-EC'"'"'] = new Object();\
DEV_PATHS['"'"'HB-UNI-Sen-EC'"'"']['"'"'50'"'"'] = '"'"'/config/img/devices/50/hb-uni-sen-ec_thumb.png'"'"';\
DEV_PATHS['"'"'HB-UNI-Sen-EC'"'"']['"'"'250'"'"'] = '"'"'/config/img/devices/250/hb-uni-sen-ec.png'"'"';\
if (typeof switch_on  === '"'"'undefined'"'"') { var switch_on  = '"'"'Ein'"'"'; }\
if (typeof switch_off === '"'"'undefined'"'"') { var switch_off = '"'"'Aus'"'"'; }\
if (typeof switch_on_english  === '"'"'undefined'"'"') { var switch_on_english  = '"'"'On'"'"';  }\
if (typeof switch_off_english === '"'"'undefined'"'"') { var switch_off_english = '"'"'Off'"'"'; }'

webui_apply()
{
  if grep -q "${WEBUI_MARKER}" "${WEBUI_JS}" 2>/dev/null; then
    echo "### webui.js DEV_LIST already patched, skipping" | tee -a $TMP_LOGFILE
  else
    ANCHOR_LINE=$(grep -n "${WEBUI_ANCHOR}" "${WEBUI_JS}" | head -1 | cut -d: -f1)
    if [ -z "${ANCHOR_LINE}" ]; then
      echo "### webui.js: DEV_LIST anchor not found, skipping" | tee -a $TMP_LOGFILE | tee -a $TMP_ERRFILE
    else
      sed -i "${ANCHOR_LINE}a\\
${WEBUI_INSERT}" "${WEBUI_JS}"
      echo "### webui.js DEV_LIST patched at line ${ANCHOR_LINE}" | tee -a $TMP_LOGFILE
    fi
  fi

  if grep -q "${WEBUI_ELVST_MARKER}" "${WEBUI_JS}" 2>/dev/null; then
    echo "### webui.js elvST already patched, skipping" | tee -a $TMP_LOGFILE
  else
    ELVST_LINE=$(grep -n "${WEBUI_ELVST_ANCHOR}" "${WEBUI_JS}" | head -1 | cut -d: -f1)
    if [ -z "${ELVST_LINE}" ]; then
      echo "### webui.js: elvST anchor not found, skipping" | tee -a $TMP_LOGFILE | tee -a $TMP_ERRFILE
    else
      ELVST_INSERT_LINE=$((ELVST_LINE - 1))
      sed -i "${ELVST_INSERT_LINE}a\\
elvST['HB_GENERIC'] = 'Pool Waermepumpe';elvST['HB_GENERIC|HB_PH'] = '\${stringTableHbPh}';elvST['HB_GENERIC|HB_ORP'] = '\${stringTableHbOrp}';elvST['HB_GENERIC|HB_ORPOFFSET'] = '\${stringTableHbOrpOffset}';elvST['HB_GENERIC|HB_TOGGLEWAITTIME'] = '\${stringTableHbToggleWaitTime}';elvST['HB_GENERIC|HB_FLOWRATE_QFACTOR'] = '\${stringTableHbFlowrateQFactor}';elvST['HB_GENERIC|HB_FLOW_RATE'] = '\${stringTableHbFlowrate}';elvST['HB_GENERIC|TEMPERATURE_OFFSET_1'] = '\${stringTableHbTemperatureOffset1}';elvST['HB_GENERIC|TEMPERATURE_OFFSET_2'] = '\${stringTableHbTemperatureOffset2}';elvST['HB_GENERIC|TEMPERATURE_OFFSET_3'] = '\${stringTableHbTemperatureOffset3}';elvST['HB_GENERIC|UNI_PRESSURE'] = '\${stringTableUniPressure}';elvST['HB_GENERIC|INFO_MSG=HB_OPERATION_NORMAL'] = '\${stringTableHBOperationNormal}';elvST['HB_GENERIC|INFO_MSG=HB_OPERATION_CALIBRATION'] = '\${stringTableHBOperationCalibration}';elvST['HB_GENERIC|INFO_MSG=HB_CALIBRATION_INVALID'] = '\${stringTableHBCalibrationInvalid}';elvST['HB_GENERIC|HB_EC'] = '\${stringTableHbEc}';elvST['HB_GENERIC|TEMPERATURE_OFFSET'] = '\${stringTableTemperatureOffset}';" "${WEBUI_JS}"
      echo "### webui.js elvST patched at line ${ELVST_INSERT_LINE}" | tee -a $TMP_LOGFILE
    fi
  fi
}

webui_revoke()
{
  sed -i '/HB-UNI-Sen-POOL-WP/d' "${WEBUI_JS}"
  sed -i '/HB-UNI-Sen-EC/d' "${WEBUI_JS}"
  sed -i '/typeof switch_on.*undefined/d;/typeof switch_off.*undefined/d' "${WEBUI_JS}"
  sed -i '/typeof switch_on_english/d;/typeof switch_off_english/d' "${WEBUI_JS}"
  sed -i "/elvST\['HB_GENERIC'\]/d" "${WEBUI_JS}"
  echo "### webui.js revoked" | tee -a $TMP_LOGFILE
}

do_patch()
{
  echo "### $2 patch file $1" | tee -a $TMP_LOGFILE | tee -a $TMP_ERRFILE
  convert_lf $1
  cd /www
  patch -N $3 -p3 -i $1 >> $TMP_LOGFILE 2>>$TMP_ERRFILE
  echo "- done" | tee -a $TMP_LOGFILE | tee -a $TMP_ERRFILE
}

patcher()
{
  if [ "$1" = "APPLY" ]; then
    echo "### Applying webui.js changes" | tee -a $TMP_LOGFILE
    webui_apply
    if [ -f "${PATCH_DIR}/${PATCHSUBDIR_COMMON}/ic_deviceparameters.cgi.patch" ]; then
      do_patch "${PATCH_DIR}/${PATCHSUBDIR_COMMON}/ic_deviceparameters.cgi.patch" "APPLY" ""
    fi
  elif [ "$1" = "REVOKE" ]; then
    echo "### Revoking webui.js changes" | tee -a $TMP_LOGFILE
    webui_revoke
    if [ -f "${PATCH_DIR}/${PATCHSUBDIR_COMMON}/ic_deviceparameters.cgi.patch" ]; then
      do_patch "${PATCH_DIR}/${PATCHSUBDIR_COMMON}/ic_deviceparameters.cgi.patch" "REVOKE" "-R"
    fi
  else
    echo "Invalid patcher() param $1" | tee -a $TMP_LOGFILE | tee -a $TMP_ERRFILE
    return
  fi
  cleanup_orig_files
}

case "$1" in
    ""|init|start)
      check_ccu_fw_version

      [ -f $TMP_ERRFILE ] && rm $TMP_ERRFILE
      [ -f $TMP_LOGFILE ] && rm $TMP_LOGFILE

      if [ ! -f ${CK_FIRMWARE_FILE} ] || [ -d ${NEW_ADDON_DIR} ]; then

        echo "Starting complete installation within '$1' $(date +"%d.%m.%Y %H:%M:%S")" | tee $TMP_LOGFILE

        check_monit
        if [ $MONIT -ge 1 ]; then
          echo "Stopping monitoring service for ReGaHss and RFD" | tee -a $TMP_LOGFILE
          /usr/bin/monit unmonitor ReGaHss
          /usr/bin/monit unmonitor rfd
        fi

        check_rega
        [ $REGA -ge 1 ] && /etc/init.d/S70ReGaHss stop | tee -a $TMP_LOGFILE

        check_rfd
        [ $RFD -ge 1 ] && /etc/init.d/S61rfd stop | tee -a $TMP_LOGFILE

        mount -o remount,rw /

        if [ -f ${CK_FIRMWARE_FILE} ] && [ -d ${PATCH_DIR} ]; then
          echo "Revoking current addon patch files." | tee -a $TMP_LOGFILE | tee -a $TMP_ERRFILE
          patcher "REVOKE"
        fi

        if [ -d ${NEW_ADDON_DIR} ]; then
          if [ -d ${ADDON_DIR} ]; then
            echo "Deleting current addon directory" | tee -a $TMP_LOGFILE
            rm -rf ${ADDON_DIR}
          fi
          echo "Renaming ${NEW_ADDON_DIR} to ${ADDON_DIR}" | tee -a $TMP_LOGFILE
          mv ${NEW_ADDON_DIR} ${ADDON_DIR}
        fi

        cd ${ADDON_DIR}

        cp -ar www/* /www/
        chown root:root /www/config/img/devices/250/hb-uni-sen-pool-wp.png 2>/dev/null
        chmod 755      /www/config/img/devices/250/hb-uni-sen-pool-wp.png 2>/dev/null
        chown root:root /www/config/img/devices/50/hb-uni-sen-pool-wp_thumb.png 2>/dev/null
        chmod 755      /www/config/img/devices/50/hb-uni-sen-pool-wp_thumb.png 2>/dev/null

        rm -rf ${WWW_DIR}
        ln -sf ${ADDON_DIR} ${WWW_DIR}

        patcher "APPLY"

        cd ${ADDON_DIR}
        echo "Running scripts..." | tee -a $TMP_LOGFILE
        for f in ${ADDON_DIR}/inst_* ; do
          echo "  - $(basename $f)" | tee -a $TMP_LOGFILE
          ./$(basename $f) install >> $TMP_LOGFILE 2>>$TMP_ERRFILE
        done

        echo "(Re-)Creating symlinks for firmware files..." | tee -a $TMP_LOGFILE
        for f in ${ADDON_DIR}${FIRMWARE_DIR}/* ; do
          rm -f ${FIRMWARE_DIR}/$(basename $f)
          ln -s $f ${FIRMWARE_DIR}/$(basename $f)
          echo "  - $(basename $f)" | tee -a $TMP_LOGFILE
        done

        sync
        mount -o remount,ro /

        [ $RFD  -ge 1 ] && /etc/init.d/S61rfd start   | tee -a $TMP_LOGFILE
        [ $REGA -ge 1 ] && /etc/init.d/S70ReGaHss start | tee -a $TMP_LOGFILE
        if [ $MONIT -ge 1 ]; then
          echo "Starting monitoring service for ReGaHss and RFD" | tee -a $TMP_LOGFILE
          /usr/bin/monit monitor ReGaHss
          /usr/bin/monit monitor rfd
        fi

        echo "Installation done." | tee -a $TMP_LOGFILE

      else
        echo "Already installed, nothing to do."
      fi

      if [ -f ${TMP_ERRFILE} ]; then
        errors=`grep -i -E 'fail|err' ${TMP_ERRFILE}`
        if [ -z "$errors" ]; then
          echo "No errors found during installation"
          [ -f ${ADDON_DIR}/install_error ] && rm ${ADDON_DIR}/install_error
        else
          echo "Errors found during installation:"
          cat ${TMP_ERRFILE}
          touch ${ADDON_DIR}/install_error
        fi
      fi

      cp ${TMP_LOGDIR}/${ADDON_NAME}-* ${LOG_DIR}/

      if [ ! -f /www/rega/${ADDON_NAME}-error.log ]; then
        mount -o remount,rw /
        ln -s ${LOG_DIR}/${ADDON_NAME}-inst.err /www/rega/${ADDON_NAME}-error.log
        mount -o remount,ro /
      fi
    ;;

    stop)
      echo "Nothing to stop..."
    ;;

    uninstall)
      check_ccu_fw_version

      mount -o remount,rw /

      cd ${ADDON_DIR}
      echo "Running uninstall scripts..."
      for f in ${ADDON_DIR}/inst_* ; do
        echo "  - $(basename $f)"
        ./$(basename $f) uninstall > $TMP_LOGFILE 2>$TMP_ERRFILE
      done

      patcher "REVOKE"

      [ -f /www/rega/${ADDON_NAME}-error.log ] && rm /www/rega/${ADDON_NAME}-error.log

      cd ${ADDON_DIR}/www
      find . -type f | sed 's/^./\/www/' | xargs -I {} sh -c '[ -f {} ] && rm {}'

      cd /
      rm -f ${WWW_DIR}
      rm -rf ${ADDON_DIR}
      sync
      mount -o remount,ro /

      rm -f ${RC_DIR}/${ADDON_NAME}
    ;;

    restart|reload)
    ;;

    info)
      INSTALLED_VERSION=$(cat ${ADDON_DIR}/VERSION 2>/dev/null | tr -d '[:space:]')
      LATEST_VERSION=$(get_latest_version)

      echo "Info: <center><b>${ADDON_DISPLAY_NAME}</b></center><br />"
      echo "Info: <center><img src='../addons/${ADDON_NAME}/${ADDON_NAME}.png'></img></center>"
      echo "Info: <center><a href='https://github.com/${GITHUB_REPO}' target='_blank'>https://github.com/${GITHUB_REPO}</a></center>"
      echo "Version: ${INSTALLED_VERSION}"
      if [ -n "${LATEST_VERSION}" ] && [ "${LATEST_VERSION}" != "${INSTALLED_VERSION}" ]; then
        echo "Available: ${LATEST_VERSION}"
        echo "Info: <br/><b>Update verfuegbar!</b> Installiert: ${INSTALLED_VERSION} &rarr; Verfuegbar: ${LATEST_VERSION}"
        echo "Download: https://github.com/${GITHUB_REPO}/releases/download/v${LATEST_VERSION}/hb-addon-${LATEST_VERSION}.tgz"
      else
        echo "Available: ${INSTALLED_VERSION}"
      fi
      echo "Name: ${ADDON_DISPLAY_NAME}"
      echo "Operations: uninstall"
    ;;

    *)
      echo "Usage: $ADDON_NAME {start|info|uninstall}" >&2
      exit 1
    ;;
esac

exit $?
